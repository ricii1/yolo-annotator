# Copy to .env and edit. Values here are loaded at server startup.
# Anything you set in the actual shell environment overrides this file.

# Path to your trained YOLO detection weights (.pt). Project classes come from it.
ANNOTATOR_MODEL_PATH=yolo11n.pt

# auto = cuda when a GPU is available, else cpu. Or force: cpu / cuda:0
ANNOTATOR_DEVICE=auto

# Where images and the SQLite db are stored.
ANNOTATOR_DATA_DIR=./data

# Edit-lock lifetime in seconds (refreshed by heartbeat while a tab is open).
ANNOTATOR_LOCK_TTL=60

# Optional default folder for the "Scan folder" button (a path on the SERVER).
# ANNOTATOR_SCAN_DIR=/data/raw_images

# Train/val split used by export.
ANNOTATOR_DEFAULT_VAL_RATIO=0.2
